@page
@model MyProfileModel
@{
	ViewData["Title"] = "My Profile";
	var successMsg = TempData["StatusMessage"] as string;
}

<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-md-8">
            
			@* Alerts *@
			@if (!string.IsNullOrEmpty(successMsg))
			{
				<div class="alert alert-success alert-dismissible fade show">
					@successMsg
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}
			@if (!string.IsNullOrEmpty(Model.ErrorMessage))
			{
				<div class="alert alert-danger alert-dismissible fade show">
					@Model.ErrorMessage
					<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
				</div>
			}

			@* CARD 1: Profile Details *@
			<div class="card shadow border-0 mb-4">
				<div class="card-header bg-primary text-white py-3">
					<h5 class="mb-0"><i class="bi bi-person-gear me-2"></i>Account Settings</h5>
				</div>
				<div class="card-body p-4">
					<form method="post" enctype="multipart/form-data">
						<input type="hidden" asp-for="ProfileInput.Udid" />
						<input type="hidden" asp-for="TargetUserId" />
						<input type="hidden" asp-for="ProfileInput.Photo" />

						<div class="row mb-4 text-center">
							<div class="col-12">
								@if (Model.ProfileInput?.Photo != null)
								{
									<img src="data:image/png;base64,@Convert.ToBase64String(Model.ProfileInput.Photo)"
										 class="rounded-circle img-thumbnail mb-3"
										 style="width: 150px; height: 150px; object-fit: cover;" />
								}
								else
								{
									<div class="bg-light rounded-circle d-inline-block mb-3 border"
										 style="width: 150px; height: 150px; line-height: 150px;">
										<i class="bi bi-person text-secondary" style="font-size: 4rem;"></i>
									</div>
								}
								<div class="mx-auto" style="max-width: 300px;">
									<label class="form-label small fw-bold">Update Profile Photo</label>
									<input asp-for="UploadedPhoto" type="file" class="form-control form-control-sm" accept="image/*" />
								</div>
							</div>
						</div>

						<div class="row mb-3">
							<div class="col-md-6">
								<label class="form-label fw-bold">Full Name</label>
								<input asp-for="ProfileInput.FullName" class="form-control" />
							</div>
							<div class="col-md-6">
								<label class="form-label fw-bold">Phone Number</label>
								<input asp-for="ProfileInput.Phone" class="form-control" />
							</div>
						</div>

						<div class="mb-3">
							<label class="form-label fw-bold">Address</label>
							<textarea asp-for="ProfileInput.Address" class="form-control" rows="2"></textarea>
						</div>

						<div class="row mb-3">
							<div class="col-md-6">
								<label class="form-label fw-bold">City</label>
								<input asp-for="ProfileInput.City" class="form-control" />
							</div>
							<div class="col-md-6">
								<label class="form-label fw-bold">Post Code</label>
								<input asp-for="ProfileInput.PostCode" class="form-control" />
							</div>
						</div>

						<div class="d-flex justify-content-between mt-4">
							<a asp-page="@Model.DashboardLink" class="btn btn-outline-secondary">Back</a>
							<button type="submit" class="btn btn-primary px-4">Update Profile</button>
						</div>
					</form>
				</div>
			</div>

			@if (User.IsInRole("Admin") && Model.TargetUserId != Model.LoggedInUserId)
			{
				@* CARD 2: Security / Password Change *@
				<div class="card shadow border-0">
					<div class="card-header bg-dark text-white py-3">
						<h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>Security Settings</h5>
					</div>
					<div class="card-body p-4">
						<p class="text-muted small">Update the account password below.</p>
						<form method="post" asp-page-handler="ChangePassword">
							@* Very important: Include TargetUserId here so the handler knows who to update *@
							<input type="hidden" asp-for="TargetUserId" />

							<div class="row">
								<div class="col-md-6 mb-3">
									<label class="form-label fw-bold">New Password</label>
									<input asp-for="NewPassword" type="password" class="form-control" />
								</div>
								<div class="col-md-6 mb-3">
									<label class="form-label fw-bold">Confirm Password</label>
									<input asp-for="ConfirmPassword" type="password" class="form-control" />
								</div>
							</div>
							<div class="d-flex justify-content-between align-items-center mt-3">
								<a asp-page="@Model.DashboardLink" class="btn btn-outline-secondary">Back</a>
								<button type="submit" class="btn btn-warning px-4">
									Reset User Password
								</button>
							</div>
						</form>
					</div>
				</div>
			}

		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}