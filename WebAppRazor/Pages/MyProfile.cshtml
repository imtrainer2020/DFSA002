@page
@model MyProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-person-gear me-2"></i>Account Settings</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="ProfileInput.Udid" />
                        <input type="hidden" asp-for="ProfileInput.UserId" />

                        <div class="row mb-4 text-center">
                            <div class="col-12">
                                @if (Model.ProfileInput?.Photo != null)
                                {
                                    <img src="data:image/png;base64,@Convert.ToBase64String(Model.ProfileInput.Photo)"
                                         class="rounded-circle img-thumbnail mb-3"
                                         style="width: 150px; height: 150px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-circle d-inline-block mb-3 border"
                                         style="width: 150px; height: 150px; line-height: 150px;">
                                        <i class="bi bi-person text-secondary" style="font-size: 4rem;"></i>
                                    </div>
                                }
                                <div class="mx-auto" style="max-width: 300px;">
                                    <label class="form-label small fw-bold">Update Profile Photo</label>
                                    <input asp-for="UploadedPhoto" type="file" class="form-control form-control-sm" accept="image/*" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Full Name</label>
                                <input asp-for="ProfileInput.FullName" class="form-control" placeholder="Enter your full name" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phone Number</label>
                                <input asp-for="ProfileInput.Phone" class="form-control" placeholder="+1 234 567 890" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Home Address</label>
                            <textarea asp-for="ProfileInput.Address" class="form-control" rows="2"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">City</label>
                                <input asp-for="ProfileInput.City" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Post Code</label>
                                <input asp-for="ProfileInput.PostCode" class="form-control" />
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            <a asp-page="@Model.DashboardLink" class="btn btn-outline-secondary">Back to Dashboard</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Save Profile</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}