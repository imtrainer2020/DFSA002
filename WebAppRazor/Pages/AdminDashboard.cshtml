@page
@model AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var currentError = TempData["ErrorMessage"] as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Admin Dashboard</h2>
        <div>
            <span class="me-3 text-muted">Welcome, @User.Identity.Name</span>
            <a class="btn btn-outline-primary btn-sm" asp-page="/MyProfile">My Profile</a>
            <a asp-page-handler="Logout" class="btn btn-outline-danger btn-sm">Logout</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }
    @if (!string.IsNullOrEmpty(currentError))
    {
        <div class="alert alert-danger">@currentError</div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white font-weight-bold">User Management</div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td>@user.Email</td>
                            <td><span class="badge @(user.Role == "Admin" ? "bg-primary" : "bg-info")">@user.Role</span></td>
                            <td class="text-center">
                                <div class="btn-group">
                                    @* Pass the specific userId to the Profile page *@
                                    <a asp-page="/MyProfile" asp-route-userId="@user.UserId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    
                                    @* Delete requires a form to use OnPost *@
                                    <form method="post" asp-page-handler="DeleteUser" asp-route-userId="@user.UserId"
                                          onsubmit="return confirm('Are you sure you want to delete this user?');" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>