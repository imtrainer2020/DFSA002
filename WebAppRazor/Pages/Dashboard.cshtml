@page
@model WebAppRazor.Pages.DashboardModel
@{
    ViewData["Title"] = "User Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow">
                <div class="card-body text-center p-5">
                    @* Displaying the email here *@
                    <div class="mb-2 text-primary fw-bold">
                        Logged in as: @User.Identity.Name
                    </div>

                    <div class="mb-4">
                        <i class="bi bi-person-circle text-primary" style="font-size: 4rem;"></i>
                    </div>
                    
                    @* Or inside the main heading *@
                    <h1 class="display-6">Welcome back!</h1>
                    <p class="lead text-muted">You are accessing your private user dashboard.</p>
                    
                    <hr class="my-4">
                    
                    <div class="row g-3">
                        <div class="col-6">
                            <a class="btn btn-outline-primary w-100" asp-page="/MyProfile">My Profile</a>
                        </div>
                        <div class="col-6">
                            <a class="btn btn-outline-secondary w-100" asp-page-handler="Logout">Sign Out</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>